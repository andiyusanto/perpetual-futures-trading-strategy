# Exchange Credentials
EXCHANGE_ID=binanceusdm
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_PASSPHRASE=          # Required for OKX/Bybit; leave blank for Binance
EXCHANGE_TESTNET=true

# Trading Parameters
TRADING_SYMBOL=BTC/USDT:USDT
TRADING_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,HYPE/USDT:USDT   # multi-symbol (apfts-multi-bot)
TRADING_LEVERAGE=5
TRADING_TIMEFRAME=1m
MAX_POSITION_PCT=0.10

# Risk Limits
MAX_DRAWDOWN_PCT=15.0
MAX_DAILY_LOSS_PCT=5.0
KILL_SWITCH_DRAWDOWN=20.0

# Logging
LOG_LEVEL=INFO

# Notifications — Telegram (leave blank to disable)
NOTIFY_TELEGRAM_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
# Notifications — Discord webhook (leave blank to disable)
NOTIFY_DISCORD_WEBHOOK_URL=
NOTIFY_NOTIFY_ON_TRADE=true
NOTIFY_NOTIFY_ON_PNL=true
NOTIFY_DAILY_REPORT_HOUR_UTC=0    # UTC hour for daily PnL report (0 = midnight UTC)

# Database persistence (SQLite)
DB_ENABLED=true
DB_DB_PATH=data/trades.db

# Optional live-data improvements (Binance USDM only)
TRADING_USE_WEBSOCKET=false       # Replace 30s REST polling with WebSocket candle stream
TRADING_LIVE_LIQ_FEED=false       # Subscribe to real liquidation events
